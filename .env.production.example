# ─────────────────────────────────────────────────────────────────────────────
# Railway deployment variables (Backend)
# Add these under: Railway → your backend service → Variables.
# This file is documentation only — Railway injects real env vars at runtime.
# ─────────────────────────────────────────────────────────────────────────────

APP_NAME="Admission Backend"
APP_ENV=production
# Paste the APP_KEY from your local .env (keep it stable so tokens stay valid)
APP_KEY=base64:PASTE_YOUR_LOCAL_APP_KEY_HERE
APP_DEBUG=false
# Railway gives your service a public domain. Put it here WITHOUT a trailing slash.
# This is what builds passport photo URLs (Storage::disk('public')->url()).
APP_URL=https://YOUR-APP.up.railway.app

LOG_CHANNEL=stack
LOG_LEVEL=error

# ── Database ──────────────────────────────────────────────────────────────────
# Add Railway's MySQL plugin, then reference its variables here. In the Railway
# UI use the reference picker, e.g. set DB_HOST = ${{ MySQL.MYSQLHOST }}
DB_CONNECTION=mysql
DB_HOST=${{ MySQL.MYSQLHOST }}
DB_PORT=${{ MySQL.MYSQLPORT }}
DB_DATABASE=${{ MySQL.MYSQLDATABASE }}
DB_USERNAME=${{ MySQL.MYSQLUSER }}
DB_PASSWORD=${{ MySQL.MYSQLPASSWORD }}

# ── Framework stores (tables are created by the bundled migrations) ───────────
SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=database

# Passport photos use the 'public' disk explicitly in code
FILESYSTEM_DISK=public

# Your Vercel frontend origin (used by Sanctum for stateful requests, optional
# for pure Bearer-token auth). No https:// prefix here.
SANCTUM_STATEFUL_DOMAINS=YOUR-APP.vercel.app

MAIL_MAILER=log

# ─────────────────────────────────────────────────────────────────────────────
# Persist passport uploads across redeploys (Railway Volume)
# Railway → backend service → Settings → Volumes → New Volume
#   Mount path:  /app/storage/app/public
# Passport photos are written there via Storage::disk('public'). Mounting a
# volume at this path keeps them after every redeploy. The container recreates
# the public/storage symlink automatically on boot (php artisan storage:link),
# so no extra config is needed. Without a volume, uploads still work but reset
# on redeploy (the printed form's base64 fallback keeps working regardless).
# ─────────────────────────────────────────────────────────────────────────────
